# Base URL for metadata canonical URLs
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Facebook Pixel ID (leave empty if not using)
NEXT_PUBLIC_FB_PIXEL_ID=

# TikTok Pixel ID (leave empty if not using)
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Google Analytics / Tag ID (e.g. G-XXXXXX, leave empty if not using)
NEXT_PUBLIC_GA_ID=

# Google Sheets Apps Script Web App Webhook URL
GOOGLE_SHEETS_WEBHOOK_URL=PASTE_YOUR_WEB_APP_URL_HERE
